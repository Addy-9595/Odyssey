{
  "name": "@odyssey/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "gen:openapi": "tsx scripts/generate-openapi.ts",
    "gen:client": "orval --config orval.config.ts",
    "gen:contract": "pnpm run gen:openapi && pnpm run gen:client",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/zod-openapi": "1.4.0",
    "@neondatabase/serverless": "1.1.0",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "0.8.3",
    "hono": "4.12.27",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/node": "^20.14.0",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "orval": "8.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "3.2.6",
    "wrangler": "4.86.0"
  }
}
