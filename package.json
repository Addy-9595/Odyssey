{
  "name": "odyssey",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev:dashboard": "turbo run dev --filter=@odyssey/dashboard",
    "dev:backend": "turbo run dev --filter=@odyssey/backend",
    "gen:contract": "turbo run gen:contract",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.6.3"
  }
}
